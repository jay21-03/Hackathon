# Local development defaults.
# Vite dev proxy maps /api and /ws to http://localhost:8085.
VITE_API_BASE_URL=/api

# Production on Vercel should point to the Render backend.
# Example:
# VITE_API_BASE_URL=https://seal-hackathon-api.onrender.com/api
# VITE_WS_BASE_URL=https://seal-hackathon-api.onrender.com

# Google OAuth Web Client ID. Use the same client ID as backend GOOGLE_CLIENT_ID.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Dev only: allow role switching UI after real login.
# VITE_ENABLE_ROLE_SWITCHER=true

# Feature flags. They are enabled by default; set to false to reduce demo surface.
# VITE_ENABLE_PHASE_7=false
# VITE_ENABLE_ACADEMIC_TERMS=false
# VITE_ENABLE_SCORING=false
# VITE_ENABLE_SUBMISSIONS=false
# VITE_ENABLE_RANKING=false
# VITE_ENABLE_STAFF_INVITATIONS=false
# VITE_ENABLE_NOTIFICATIONS=false
# VITE_ENABLE_ANNOUNCEMENTS=false
# VITE_ENABLE_GITHUB_PROVISIONING=false
# VITE_ENABLE_AI_REVIEW=false
# VITE_AI_REVIEW_JUDGE_ACCESS=false
# VITE_ENABLE_AWARDS=false

# GitHub repository template defaults shown in the UI.
# VITE_GITHUB_TEMPLATE_OWNER=your-github-org
# VITE_GITHUB_TEMPLATE_REPO=your-template-repo
# VITE_GITHUB_DEFAULT_BRANCH=main
