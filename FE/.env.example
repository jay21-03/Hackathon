# API backend (Vite proxy mặc định /api -> http://localhost:8080)
# Dev 2 máy: VITE_API_BASE_URL=http://<ip-may-chay-be>:8085/api
VITE_API_BASE_URL=/api

# Google OAuth Client ID (Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Chỉ dev: đổi vai trò UI sau khi đăng nhập thật
# VITE_ENABLE_ROLE_SWITCHER=true

# Phase 7+ (chấm điểm, xếp hạng, check-in…): mặc định TẮT — không hiện menu/route
# VITE_ENABLE_PHASE_7=true

# Lời mời mentor/judge riêng (tab trên Lời mời): chưa có API
# VITE_ENABLE_STAFF_INVITATIONS=true
