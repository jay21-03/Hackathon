# API backend (Vite proxy mặc định /api -> http://localhost:8085)
# Dev 2 máy LAN: VITE_API_BASE_URL=http://<ip-may-chay-be>:8085/api
VITE_API_BASE_URL=/api

# Google OAuth Client ID (Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Chỉ dev: đổi vai trò UI sau khi đăng nhập thật
# VITE_ENABLE_ROLE_SWITCHER=true

# Phase 7 (chung kết, nộp bài, kết quả): mặc định BẬT — tắt bằng false
# VITE_ENABLE_PHASE_7=false

# Quản lý học kỳ — mặc định BẬT — tắt bằng false
# VITE_ENABLE_ACADEMIC_TERMS=false

# Chấm điểm (rubric, ma trận judge, tiến độ): mặc định BẬT — tắt bằng false
# VITE_ENABLE_SCORING=false

# Bài nộp (link GitHub/GitLab): mặc định BẬT — tắt bằng false
# VITE_ENABLE_SUBMISSIONS=false

# Xếp hạng & công bố kết quả (phase 8): mặc định BẬT — tắt bằng false
# VITE_ENABLE_RANKING=false

# Lời mời mentor/judge (tab trên /organizer/invitations) — mặc định bật
# VITE_ENABLE_STAFF_INVITATIONS=false

# Thông báo in-app (phase 9): mặc định BẬT — tắt bằng false
# VITE_ENABLE_NOTIFICATIONS=false

# Thông báo chung BTC → participant/staff (phase 9): mặc định BẬT
# VITE_ENABLE_ANNOUNCEMENTS=false

# Provision repository GitHub (BTC + thí sinh): mặc định BẬT — tắt bằng false
# VITE_ENABLE_GITHUB_PROVISIONING=false

# Đánh giá AI repository: mặc định BẬT — tắt bằng false (backend cần AI_API_KEY)
# VITE_ENABLE_AI_REVIEW=false
# VITE_AI_REVIEW_JUDGE_ACCESS=false

# Trao giải BTC: mặc định BẬT — tắt bằng false
# VITE_ENABLE_AWARDS=false

# Mẫu repo GitHub — chỉ cần nếu khác mặc định trong githubRepoDefaults.ts
# VITE_GITHUB_TEMPLATE_OWNER=your-github-org
# VITE_GITHUB_TEMPLATE_REPO=your-template-repo
# VITE_GITHUB_DEFAULT_BRANCH=main
