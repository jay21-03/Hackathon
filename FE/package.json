{
  "name": "seal-hackathon-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint \"src/**/*.{ts,tsx}\" && npm run typecheck",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test:e2e": "playwright test -c playwright.live.config.ts",
    "test:e2e:mock": "playwright test --ignore tests/e2e/live",
    "test:ci": "npm run build && npm run test:e2e:mock",
    "test:e2e:ui": "playwright test -c playwright.live.config.ts --ui"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-react": "^11.2.0",
    "@react-oauth/google": "^0.13.5",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.8.4",
    "ckeditor5": "^48.2.0",
    "dompurify": "^3.4.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^5.4.10"
  }
}
