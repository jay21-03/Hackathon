# P3 — Legacy n8n pipeline (Supabase + Firebase + Vertex/Gemini)
# Copy vào Hackathon/.env khi chạy workflow 1–3 thay vì platform bridge

# Supabase (bắt buộc cho WF3)
N8N_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
N8N_SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Firebase Realtime Database (WF2 metadata — tùy chọn, pipeline chạy được khi bỏ trống)
N8N_FIREBASE_DATABASE_URL=https://YOUR_PROJECT-default-rtdb.firebaseio.com
N8N_FIREBASE_ACCESS_TOKEN=
# Lấy token: gcloud auth print-access-token (SA có quyền Firebase) hoặc OAuth từ SA JSON

# GitHub (WF2 + Issue)
# Dùng chung GITHUB_PAT trong .env — map credential httpBearerAuth trong n8n

# Gemini / Vertex
# Platform bridge: GEMINI_API_KEY = AI_API_KEY (đã có trong docker-compose n8n)
# Vertex native: thêm Google Service Account credential trong n8n (xem SETUP.md)

# Workflow IDs sau import (Settings → workflow → copy ID)
N8N_PROCESS_SINGLE_REPO_WORKFLOW_ID=
N8N_LLM_HACKATHON_WORKFLOW_ID=

# BE webhook secret (WF1 gọi GET /legacy-repos) — trùng N8N_AI_REVIEW_WEBHOOK_SECRET
N8N_AI_REVIEW_WEBHOOK_SECRET=

# URL BE từ container n8n (không dùng localhost)
N8N_BACKEND_URL=http://host.docker.internal:8085

# Repo test thêm (optional) — repo đã provision tự lấy từ BE
N8N_REPO_LIST=owner/repo-test
