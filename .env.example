# Copy to Hackathon/.env — docker compose reads this file.
# Local BE via run-dev.ps1 uses BE/run-dev.ps1 env vars instead of this file.

POSTGRES_DB=seal_hackathon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SERVER_PORT=8085
# Docker BE: jdbc:postgresql://postgres:5432/seal_hackathon
# Local BE (run-dev.ps1): jdbc:postgresql://localhost:5433/seal_hackathon
DB_URL=jdbc:postgresql://postgres:5432/seal_hackathon
DB_USERNAME=postgres
DB_PASSWORD=postgres

GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAINS=fpt.edu.vn,fe.edu.vn,gmail.com,seal.edu.vn

JWT_SECRET=local_dev_secret_change_me_please_32_chars_minimum
JWT_EXPIRATION_MINUTES=1440

APP_BOOTSTRAP_ORGANIZER_EMAIL=your-organizer@gmail.com
DEV_BOOTSTRAP_ORGANIZER_EMAIL=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Dev 2 máy LAN: thêm http://192.168.x.x:5173
DEV_AUTH_ENABLED=false

MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@seal-hackathon.local
# URL thí sinh mở được từ email — dùng IP LAN nếu test 2 máy
INVITATION_BASE_URL=http://localhost:5173

APP_INVITATION_TOKEN_SECRET=dev-invite-secret-change-me
AI_API_KEY=
AI_REVIEW_INTERVAL_MINUTES=30
FILE_STORAGE_PATH=./storage
