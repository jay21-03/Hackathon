# Copy to .env for local Docker Compose only.
# Do not commit real secrets. Set production secrets directly in Render/Vercel.

# ---------------------------------------------------------------------------
# Local Docker/Postgres
# ---------------------------------------------------------------------------
POSTGRES_DB=seal_hackathon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SERVER_PORT=8085
DB_URL=jdbc:postgresql://postgres:5432/seal_hackathon
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ---------------------------------------------------------------------------
# Render + Neon production example
# ---------------------------------------------------------------------------
# Render injects PORT automatically. application.yml also supports SERVER_PORT.
# PORT=10000
APP_FRONTEND_URL=https://your-vercel-app.vercel.app
CORS_ALLOWED_ORIGINS=https://your-vercel-app.vercel.app

# Neon JDBC URL must use SSL.
# Prefer SPRING_DATASOURCE_* on Render; DB_* remains supported for local/Docker.
SPRING_DATASOURCE_URL=jdbc:postgresql://your-neon-host.neon.tech/your-db?sslmode=require
SPRING_DATASOURCE_USERNAME=your-neon-user
SPRING_DATASOURCE_PASSWORD=your-neon-password
DB_MAX_POOL_SIZE=5
DB_MIN_IDLE=1
DB_CONNECTION_TIMEOUT_MS=30000

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAINS=fpt.edu.vn,fe.edu.vn,gmail.com,seal.edu.vn

# Use a strong random value in production. Changing this logs users out.
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRATION_MINUTES=1440

# First matching login email can be bootstrapped as organizer.
APP_BOOTSTRAP_ORGANIZER_EMAIL=your-organizer@gmail.com
DEV_BOOTSTRAP_ORGANIZER_EMAIL=
DEV_AUTH_ENABLED=false

# ---------------------------------------------------------------------------
# Email
# ---------------------------------------------------------------------------
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@seal-hackathon.local
INVITATION_BASE_URL=https://your-vercel-app.vercel.app
MAIL_API_BASE_URL=https://your-render-service.onrender.com
INVITATION_REMINDER_ENABLED=true
INVITATION_REMINDER_HOURS=24

APP_INVITATION_TOKEN_SECRET=replace-with-a-strong-invitation-token-secret

# Render Free filesystem is ephemeral. Do not rely on this for important files.
FILE_STORAGE_PATH=/tmp/seal-hackathon-storage

# ---------------------------------------------------------------------------
# GitHub provisioning / webhooks
# ---------------------------------------------------------------------------
GITHUB_MODE=pat
GITHUB_ORG=
GITHUB_PAT=
GITHUB_DEFAULT_BRANCH=main
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=
GITHUB_SCHEDULER_ENABLED=false
GITHUB_SCHEDULER_POLL_MS=180000
GITHUB_WEBHOOK_SECRET=replace-with-a-strong-github-webhook-secret
GITHUB_WEBHOOK_URL=https://your-render-service.onrender.com/api/v1/webhooks/github
GITHUB_WEBHOOK_AUTO_REGISTER=true

# ---------------------------------------------------------------------------
# AI review / n8n bridge
# ---------------------------------------------------------------------------
AI_API_KEY=
AI_REVIEW_SCHEDULER_ENABLED=false
AI_REVIEW_INTERVAL_MINUTES=60
AI_REVIEW_POLL_MS=3600000
AI_REVIEW_BATCH_WINDOW_HOURS=1
AI_REVIEW_INITIAL_DELAY_MS=60000
AI_REVIEW_MODEL=gemini-2.0-flash
AI_REVIEW_GITHUB_ISSUES_ENABLED=false
AI_REVIEW_WEBHOOK_ENABLED=true
AI_REVIEW_WEBHOOK_DEBOUNCE_MS=60000
AI_REVIEW_NOTIFICATIONS_ENABLED=true
AI_REVIEW_MANUAL_COOLDOWN_SECONDS=30
AI_REVIEW_MAX_COMMITS_PER_RUN=100
AI_REVIEW_JUDGE_ACCESS_ENABLED=true
N8N_AI_REVIEW_WEBHOOK_SECRET=replace-with-a-strong-n8n-webhook-secret
AI_REVIEW_RETRY_FAILED_ENABLED=false
AI_REVIEW_RETRY_FAILED_POLL_MS=600000
