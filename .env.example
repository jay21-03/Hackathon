# Copy to Hackathon/.env — docker compose reads this file.
# Local BE via run-dev.ps1 uses BE/run-dev.ps1 env vars instead of this file.
#
# Dev local: dùng .\start-dev.ps1 (Docker BE+Postgres). Không chạy BE\run-dev.ps1 song song.
# Sau khi đổi JWT_SECRET: logout/login lại trên FE.
POSTGRES_DB=seal_hackathon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

SERVER_PORT=8085
# Docker BE: jdbc:postgresql://postgres:5432/seal_hackathon
# Local BE (run-dev.ps1): jdbc:postgresql://localhost:5433/seal_hackathon
DB_URL=jdbc:postgresql://postgres:5432/seal_hackathon
DB_USERNAME=postgres
DB_PASSWORD=postgres

GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAINS=fpt.edu.vn,fe.edu.vn,gmail.com,seal.edu.vn

JWT_SECRET=local_dev_secret_change_me_please_32_chars_minimum
JWT_EXPIRATION_MINUTES=1440

# Email Google đăng nhập lần đầu → tự gán quyền ORGANIZER (xem AuthBootstrapService)
APP_BOOTSTRAP_ORGANIZER_EMAIL=your-organizer@gmail.com
DEV_BOOTSTRAP_ORGANIZER_EMAIL=

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Dev 2 máy LAN: thêm http://192.168.x.x:5173
# false = bắt buộc Google OAuth. true = chỉ fallback local dev.
DEV_AUTH_ENABLED=false

# Gửi email lời mời GK/mentor: MAIL_ENABLED=true + điền MAIL_USERNAME/PASSWORD (Gmail: App Password)
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@seal-hackathon.local
# URL thí sinh mở được từ email — dùng IP LAN nếu test 2 máy
INVITATION_BASE_URL=http://localhost:5173
# URL backend cho pixel/link tracking email (mặc định :8085)
MAIL_API_BASE_URL=http://localhost:8085
# Nhắc email trước khi hết hạn (giờ, mặc định 24)
INVITATION_REMINDER_ENABLED=true
INVITATION_REMINDER_HOURS=24

APP_INVITATION_TOKEN_SECRET=dev-invite-secret-change-me
FILE_STORAGE_PATH=./storage

# GitHub repo provisioning — web hiện tại chỉ cần PAT
GITHUB_MODE=pat
GITHUB_ORG=
GITHUB_PAT=
GITHUB_DEFAULT_BRANCH=main
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_VERSION=2026-03-10
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=
GITHUB_SCHEDULER_ENABLED=false
GITHUB_SCHEDULER_POLL_MS=180000
# Push webhook tự tạo khi BTC cấp repo (cần URL public + secret)
GITHUB_WEBHOOK_SECRET=change-me-github-webhook-secret
GITHUB_WEBHOOK_URL=http://localhost:8085/api/v1/webhooks/github
# true = tự gọi POST /repos/{owner}/{repo}/hooks khi provision (mặc định true)
GITHUB_WEBHOOK_AUTO_REGISTER=true

# AI Review — handover: scheduler mỗi 1 giờ, batch window 1 giờ
AI_API_KEY=
AI_REVIEW_SCHEDULER_ENABLED=true
AI_REVIEW_INTERVAL_MINUTES=60
AI_REVIEW_POLL_MS=3600000
AI_REVIEW_BATCH_WINDOW_HOURS=1
AI_REVIEW_INITIAL_DELAY_MS=60000
AI_REVIEW_MODEL=gemini-2.0-flash
AI_REVIEW_GITHUB_ISSUES_ENABLED=true
AI_REVIEW_WEBHOOK_ENABLED=true
AI_REVIEW_WEBHOOK_DEBOUNCE_MS=60000
AI_REVIEW_NOTIFICATIONS_ENABLED=true
AI_REVIEW_MANUAL_COOLDOWN_SECONDS=30
AI_REVIEW_MAX_COMMITS_PER_RUN=100
AI_REVIEW_JUDGE_ACCESS_ENABLED=true
N8N_AI_REVIEW_WEBHOOK_SECRET=change-me-n8n-webhook-secret
AI_REVIEW_RETRY_FAILED_ENABLED=true
AI_REVIEW_RETRY_FAILED_POLL_MS=600000
